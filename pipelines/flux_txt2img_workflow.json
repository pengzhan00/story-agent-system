{
  "1": {
    "class_type": "CheckpointLoaderSimple",
    "inputs": {
      "ckpt_name": "flux_2_klein_9B/flux-2-klein-9b.safetensors"
    }
  },

  "2": {
    "class_type": "EmptyFlux2LatentImage",
    "inputs": {
      "width":      832,
      "height":     480,
      "batch_size": 1
    }
  },

  "3": {
    "class_type": "CLIPTextEncodeFlux",
    "inputs": {
      "clip":     ["1", 1],
      "clip_l":   "",
      "t5xxl":    "anime scene, cinematic composition, high quality, detailed",
      "guidance": 3.5
    }
  },

  "4": {
    "class_type": "ModelSamplingFlux",
    "inputs": {
      "model":      ["1", 0],
      "max_shift":  1.15,
      "base_shift": 0.5,
      "width":      832,
      "height":     480
    }
  },

  "5": {
    "class_type": "KSampler",
    "inputs": {
      "model":         ["4", 0],
      "positive":      ["3", 0],
      "negative":      ["3", 0],
      "latent_image":  ["2", 0],
      "steps":         20,
      "cfg":           1.0,
      "sampler_name":  "euler",
      "scheduler":     "simple",
      "seed":          0,
      "denoise":       1.0
    }
  },

  "6": {
    "class_type": "VAEDecode",
    "inputs": {
      "samples": ["5", 0],
      "vae":     ["1", 2]
    }
  },

  "7": {
    "class_type": "SaveImage",
    "inputs": {
      "images":          ["6", 0],
      "filename_prefix": "flux_frame"
    }
  }
}
